<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <defs>
    <radialGradient id="bg" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#1a0808"/>
      <stop offset="100%" stop-color="#070408"/>
    </radialGradient>
    <radialGradient id="glow" cx="50%" cy="60%" r="50%">
      <stop offset="0%" stop-color="#ff6b00" stop-opacity="0.4"/>
      <stop offset="100%" stop-color="transparent"/>
    </radialGradient>
    <linearGradient id="archGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#8B4513"/>
      <stop offset="50%" stop-color="#6B3410"/>
      <stop offset="100%" stop-color="#7a3a1a"/>
    </linearGradient>
    <linearGradient id="baseGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#6B3410"/>
      <stop offset="100%" stop-color="#4a2008"/>
    </linearGradient>
    <linearGradient id="fireGrad" x1="0%" y1="100%" x2="0%" y2="0%">
      <stop offset="0%" stop-color="#ff6b00"/>
      <stop offset="60%" stop-color="#ffcc00"/>
      <stop offset="100%" stop-color="rgba(255,255,200,0)"/>
    </linearGradient>
  </defs>

  <!-- Background circle -->
  <circle cx="256" cy="256" r="256" fill="url(#bg)"/>
  <circle cx="256" cy="256" r="256" fill="url(#glow)"/>

  <!-- Orange ring border -->
  <circle cx="256" cy="256" r="240" fill="none" stroke="#ff6b00" stroke-width="8" opacity="0.6"/>
  <circle cx="256" cy="256" r="230" fill="none" stroke="#ff6b00" stroke-width="2" opacity="0.2"/>

  <!-- OVEN ARCH -->
  <ellipse cx="256" cy="210" rx="155" ry="155" fill="url(#archGrad)"/>
  <rect x="101" y="210" width="310" height="80" fill="url(#archGrad)"/>

  <!-- Arch highlight -->
  <ellipse cx="256" cy="210" rx="148" ry="148" fill="none" stroke="rgba(255,180,80,0.12)" stroke-width="10"/>

  <!-- OVEN MOUTH -->
  <ellipse cx="256" cy="228" rx="100" ry="82" fill="#110300"/>
  <rect x="156" y="228" width="200" height="72" fill="#110300"/>

  <!-- Fire inside -->
  <ellipse cx="256" cy="288" rx="75" ry="22" fill="rgba(255,100,0,0.35)"/>

  <!-- Flames -->
  <path d="M186,290 Q193,255 207,268 Q213,245 226,272 Q220,238 240,258 Q243,232 256,252 Q261,228 272,255 Q268,235 282,260 Q290,245 298,268 Q305,255 312,272 Q316,258 326,290 Z"
        fill="url(#fireGrad)" opacity="0.92"/>

  <!-- OVEN BASE -->
  <rect x="96" y="285" width="320" height="95" rx="18" fill="url(#baseGrad)"/>
  <rect x="96" y="285" width="320" height="12" rx="0" fill="#7a3a1a"/>

  <!-- Stone floor -->
  <rect x="164" y="298" width="48" height="18" rx="7" fill="#777"/>
  <rect x="218" y="298" width="48" height="18" rx="7" fill="#666"/>
  <rect x="272" y="298" width="48" height="18" rx="7" fill="#777"/>

  <!-- Chimney -->
  <rect x="330" y="105" width="38" height="88" rx="5" fill="#6B3410"/>
  <rect x="323" y="98" width="52" height="16" rx="5" fill="#7a3a1a"/>

  <!-- Smoke puffs -->
  <circle cx="349" cy="78" r="14" fill="rgba(200,200,200,0.18)"/>
  <circle cx="340" cy="55" r="10" fill="rgba(200,200,200,0.12)"/>
  <circle cx="353" cy="36" r="7" fill="rgba(200,200,200,0.08)"/>

  <!-- PIZZA emoji on paddle -->
  <text x="128" y="310" font-size="68" text-anchor="middle" opacity="0.9">🍕</text>
  <!-- Paddle handle -->
  <rect x="62" y="306" width="90" height="9" rx="4" fill="#6B3410" transform="rotate(-8,62,310)"/>

  <!-- Label -->
  <text x="256" y="358" text-anchor="middle" fill="rgba(255,220,150,0.65)" font-size="22"
        font-family="'Courier New',monospace" font-weight="900" letter-spacing="4">FORNO NAPOLETANO</text>

  <!-- Title at bottom -->
  <text x="256" y="415" text-anchor="middle" fill="#ff6b00" font-size="42"
        font-family="Arial Black,sans-serif" font-weight="900" letter-spacing="3">PIZZA</text>
  <text x="256" y="458" text-anchor="middle" fill="rgba(255,200,100,0.85)" font-size="28"
        font-family="Arial,sans-serif" font-weight="700" letter-spacing="5">CLICKER</text>
</svg>
