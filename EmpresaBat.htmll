// ==================== STATE ====================
let G = {
  user: null,
  uid: null,
  gameData: null,
  currentTab: 'dashboard',
  rankingOpen: false,
  otherPlayers: [],
  activeEvents: [],
  initialized: false,
};

function defaultGameData(uid, displayName) {
  const now = new Date(2024, 0, 1);
  return {
    uid,
    displayName,
    mode: null, // 'create' | 'hired'
    week: 1,
    year: 2024,
    month: 1,
    date: now.toISOString(),
    prestigi: 0,
    company: null,
    finances: {
      cash: 0,
      monthly_revenue: 0,
      monthly_costs: 0,
      annual_revenue: 0,
      annual_costs: 0,
      loans: [],
      revenue_history: [],
      actiu: { immobilitzat: 0, existencies: 10000, tresoreria: 0, clients: 0 },
      passiu: { capital: 0, reserves: 0, deutes_llarg: 0, deutes_curt: 0, proveidors: 0 },
    },
    employees: [],
    machines: [],
    marketing: { channels: {}, sponsors: [] },
    clients: [],
    claims: [],
    notifications: [],
    events: [],
    mktBudget: 0,
    lastSaved: Date.now(),
  };
}

// ==================== FIREBASE ====================
window.doLogin = async function() {
  const email = document.getElementById('login-email').value.trim();
  const pass = document.getElementById('login-pass').value;
  if (!email || !pass) { showAuthErr('Introdueix correu i contrasenya.'); return; }
  try {
    const btn = document.querySelector('#login-form .auth-btn');
    btn.disabled = true; btn.textContent = 'Entrant...';
    await signInWithEmailAndPassword(auth, email, pass);
  } catch(e) {
    showAuthErr('Error: ' + e.message);
    document.querySelector('#login-form .auth-btn').disabled = false;
    document.querySelector('#login-form .auth-btn').textContent = 'Entrar al simulador →';
  }
};

window.doRegister = async function() {
  const name = document.getElementById('reg-name').value.trim();
  const surname = document.getElementById('reg-surname').value.trim();
  const email = document.getElementById('reg-email').value.trim();
  const pass = document.getElementById('reg-pass').value;
  if (!name || !surname || !email || !pass) { showAuthErr('Omple tots els camps.'); return; }
  if (pass.length < 6) { showAuthErr('La contrasenya ha de tenir mínim 6 caràcters.'); return; }
  try {
    const btn = document.querySelector('#register-form .auth-btn');
    btn.disabled = true; btn.textContent = 'Creant compte...';
    const cred = await createUserWithEmailAndPassword(auth, email, pass);
    const gd = defaultGameData(cred.user.uid, name + ' ' + surname);
    await setDoc(doc(db, 'games', cred.user.uid), gd);
  } catch(e) {
    showAuthErr('Error: ' + e.message);
    document.querySelector('#register-form .auth-btn').disabled = false;
    document.querySelector('#register-form .auth-btn').textContent = 'Crear compte →';
  }
};

window.doLogout = async function() {
  await signOut(auth);
  closeProfile();
};

function showAuthErr(msg) {
  const el = document.getElementById('auth-err');
  el.textContent = msg;
  el.style.display = 'block';
}

window.switchAuthTab = function(t) {
  document.getElementById('auth-err').style.display = 'none';
  document.getElementById('login-form').style.display = t==='login' ? '' : 'none';
  document.getElementById('register-form').style.display = t==='register' ? '' : 'none';
  document.querySelectorAll('.auth-tab').forEach((b,i) => b.classList.toggle('active', (t==='login'?0:1)===i));
};

onAuthStateChanged(auth, async (user) => {
  document.getElementById('loading-overlay').style.display = 'none';
  if (user) {
    G.user = user;
    G.uid = user.uid;
    document.getElementById('auth-screen').style.display = 'none';
    document.getElementById('game-screen').style.display = 'flex';
    await loadGameData();
    startRealtimeListeners();
  } else {
    document.getElementById('auth-screen').style.display = 'flex';
    document.getElementById('game-screen').style.display = 'none';
  }
});

async function loadGameData() {
  const ref = doc(db, 'games', G.uid);
  const snap = await getDoc(ref);
  if (!snap.exists()) {
    G.gameData = defaultGameData(G.uid, G.user.email.split('@')[0]);
    await setDoc(ref, G.gameData);
  } else {
    G.gameData = snap.data();
  }
  initUI();
}

async function saveGameData() {
  if (!G.gameData) return;
  G.gameData.lastSaved = Date.now();
  try {
    await setDoc(doc(db, 'games', G.uid), G.gameData);
    showToast('💾 Guardat automàticament');
  } catch(e) { console.warn('Save err:', e); }
}

function startRealtimeListeners() {
  // Listen other players for map
  const q = query(collection(db, 'games'), limit(20));
  onSnapshot(q, (snap) => {
    G.otherPlayers = [];
    snap.forEach(d => {
      if (d.id !== G.uid && d.data().company) {
        G.otherPlayers.push(d.data());
      }
    });
    if (G.currentTab === 'map') renderMap();
    renderRanking();
  });
}

// ==================== UI INIT ====================
function initUI() {
  const gd = G.gameData;
  document.getElementById('profile-name').textContent = gd.displayName || 'Jugador';
  updateTopStats();
  if (!gd.mode) {
    showSetupInit();
  } else {
    showActiveGame();
  }
  renderDashboard();
  renderFinances();
  renderHR();
  renderProduction();
  renderMarketing();
  renderSales();
  G.initialized = true;
}

function showSetupInit() {
  document.getElementById('setup-init').style.display = '';
  document.getElementById('wizard-area').style.display = 'none';
  document.getElementById('hired-area').style.display = 'none';
  document.getElementById('active-company').style.display = 'none';
}

function showActiveGame() {
  document.getElementById('setup-init').style.display = 'none';
  document.getElementById('wizard-area').style.display = 'none';
  document.getElementById('hired-area').style.display = 'none';
  document.getElementById('active-company').style.display = '';
  renderActiveCompany();
}

// ==================== MODE SELECTION ====================
window.startMode = function(mode) {
  if (mode === 'create') {
    showWizard();
  } else {
    showHiredMode();
  }
};

// ==================== WIZARD ====================
let wizardData = {};
let wizardStep = 0;
const WIZARD_STEPS = [
  {label:'Idea', render: renderStep_Idea},
  {label:'Forma Jurídica', render: renderStep_Legal},
  {label:'Pla de Negoci', render: renderStep_Plan},
  {label:'Finançament', render: renderStep_Finance},
  {label:'Constitució', render: renderStep_Const},
  {label:'Instal·lacions', render: renderStep_Location},
  {label:'Personal', render: renderStep_Staff},
];

function showWizard() {
  wizardData = {};
  wizardStep = 0;
  document.getElementById('setup-init').style.display = 'none';
  document.getElementById('wizard-area').style.display = '';
  document.getElementById('hired-area').style.display = 'none';
  renderWizardSteps();
  renderWizardStep();
}

function renderWizardSteps() {
  document.getElementById('wizard-steps').innerHTML = WIZARD_STEPS.map((s,i) => `
    <div class="w-step ${i < wizardStep ? 'done' : i === wizardStep ? 'active' : ''}">
      <div class="w-step-dot">${i < wizardStep ? '✓' : i+1}</div>
      <div class="w-step-label">${s.label}</div>
    </div>
  `).join('');
}

function renderWizardStep() {
  WIZARD_STEPS[wizardStep].render();
}

window.wizardNext = function() {
  if (!validateStep()) return;
  if (wizardStep < WIZARD_STEPS.length - 1) {
    wizardStep++;
    renderWizardSteps();
    renderWizardStep();
  } else {
    finishWizard();
  }
};

window.wizardPrev = function() {
  if (wizardStep > 0) {
    wizardStep--;
    renderWizardSteps();
    renderWizardStep();
  } else {
    showSetupInit();
  }
};

function validateStep() {
  if (wizardStep === 0) {
    wizardData.companyName = document.getElementById('wiz-name')?.value.trim();
    wizardData.sector = document.getElementById('wiz-sector')?.value;
    if (!wizardData.companyName || !wizardData.sector) { showToast('⚠️ Omple tots els camps'); return false; }
  }
  if (wizardStep === 1) {
    wizardData.legalForm = document.getElementById('wiz-legal')?.value;
  }
  if (wizardStep === 3) {
    wizardData.ownCapital = parseFloat(document.getElementById('wiz-own-capital')?.value || 0);
    wizardData.loanAmount = parseFloat(document.getElementById('wiz-loan-amount')?.value || 0);
    const forma = FORMES_JURIDIQUES.find(f => f.id === wizardData.legalForm);
    if (forma && wizardData.ownCapital < forma.capital) {
      showToast(`⚠️ El capital mínim per ${forma.name} és ${forma.capital.toLocaleString('ca')}€`);
      return false;
    }
  }
  if (wizardStep === 4) {
    wizardData.registrationDone = true;
  }
  return true;
}

function renderStep_Idea() {
  const sectors = SECTORS.map(s => `<option value="${s.id}">${s.icon} ${s.name}</option>`).join('');
  document.getElementById('wizard-panel').innerHTML = `
    <div class="wizard-title">La teva idea de negoci</div>
    <div class="wizard-subtitle">Defineix el nom i el sector de la teva futura empresa.</div>
    <div class="form-group2"><label>Nom de l'empresa</label>
      <input class="form-input" id="wiz-name" placeholder="Ex: Tecnologies Vallès SL" value="${wizardData.companyName||''}"></div>
    <div class="form-group2"><label>Sector d'activitat</label>
      <select class="form-select" id="wiz-sector">${sectors}</select></div>
    <div class="form-group2"><label>Descripció breu del negoci</label>
      <textarea class="plan-textarea" id="wiz-desc" placeholder="Descriu en 2-3 frases a que es dedicarà l'empresa...">${wizardData.desc||''}</textarea></div>
    <div class="info-box">💡 <strong>Consell:</strong> Tria un sector que coneguis. El teu coneixement del mercat serà clau per elaborar un bon pla de negoci i convèncer el banc.</div>
    <div class="wizard-nav">
      <button class="btn-prev" onclick="wizardPrev()">← Enrere</button>
      <button class="btn-next" onclick="wizardNext()">Continuar →</button>
    </div>`;
}

function renderStep_Legal() {
  const legalHtml = FORMES_JURIDIQUES.map(f => `
    <div class="offer-card" onclick="selectLegal('${f.id}')" id="legal-${f.id}" style="padding:14px;margin-bottom:8px;${wizardData.legalForm===f.id?'border-color:var(--accent);background:rgba(79,127,255,.1)':''}">
      <div style="display:flex;justify-content:space-between;align-items:start">
        <div style="font-weight:700;font-size:15px;color:var(--text)">${f.name}</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--gold)">Capital mínim: ${f.capital.toLocaleString('ca')}€</div>
      </div>
      <div style="font-size:12px;color:var(--text2);margin:6px 0">${f.desc}</div>
      <div style="display:flex;gap:12px;font-size:11px;color:var(--text3)">
        <span>👥 Socis: ${f.socis}</span>
        <span>⚖️ Resp: ${f.responsabilitat}</span>
        <span>📋 Impost: ${f.impostos}</span>
        <span>💰 Cost const: ${f.cost_const.toLocaleString('ca')}€</span>
      </div>
    </div>`).join('');
  document.getElementById('wizard-panel').innerHTML = `
    <div class="wizard-title">Forma Jurídica</div>
    <div class="wizard-subtitle">Escull com constituiràs l'empresa. Cada forma té implicacions legals, fiscals i de responsabilitat diferents.</div>
    ${legalHtml}
    <div class="info-box">⚖️ <strong>Responsabilitat:</strong> Les formes societàries (SL, SA) protegeixen el teu patrimoni personal. L'autònom no — respondràs amb tots els teus béns.</div>
    <div class="wizard-nav">
      <button class="btn-prev" onclick="wizardPrev()">← Enrere</button>
      <button class="btn-next" onclick="wizardNext()">Continuar →</button>
    </div>`;
  if (!wizardData.legalForm) { wizardData.legalForm = 'sl'; document.getElementById('legal-sl').style.borderColor = 'var(--accent)'; document.getElementById('legal-sl').style.background = 'rgba(79,127,255,.1)'; }
}

window.selectLegal = function(id) {
  FORMES_JURIDIQUES.forEach(f => {
    const el = document.getElementById('legal-' + f.id);
    if (el) { el.style.borderColor = ''; el.style.background = ''; }
  });
  wizardData.legalForm = id;
  const sel = document.getElementById('legal-' + id);
  if (sel) { sel.style.borderColor = 'var(--accent)'; sel.style.background = 'rgba(79,127,255,.1)'; }
};

function renderStep_Plan() {
  document.getElementById('wizard-panel').innerHTML = `
    <div class="wizard-title">Pla de Negoci</div>
    <div class="wizard-subtitle">El banc i els inversors demanaran un pla de negoci sòlid. La qualitat del teu pla determinarà les condicions del crèdit.</div>
    ${renderPlanSection('mercat','Anàlisi de mercat','Qui és el teu client objectiu? Quin és el mercat potencial? Hi ha demanda suficient?')}
    ${renderPlanSection('competencia','Competència','Qui competeix amb tu? Quins avantatges competitius tens?')}
    ${renderPlanSection('producte','Producte/Servei','Què vens exactament? Per què és millor que el de la competència?')}
    ${renderPlanSection('marketing','Estratègia comercial','Com arribaràs als clients? Quins canals de venda faràs servir?')}
    ${renderPlanSection('finances','Projecció financera','Quins ingressos esperes? Quan seràs rendible?')}
    <div class="warn-box">⚠️ Un pla de negoci poc elaborat reduirà les possibilitats d'aprovació del crèdit bancari i augmentarà el tipus d'interès.</div>
    <div id="plan-quality-display" style="text-align:center;font-size:14px;font-weight:700;color:var(--gold);margin-top:10px">Qualitat del pla: calculant...</div>
    <div class="wizard-nav">
      <button class="btn-prev" onclick="wizardPrev()">← Enrere</button>
      <button class="btn-next" onclick="wizardNext()">Continuar →</button>
    </div>`;
  updatePlanQuality();
}

function renderPlanSection(id, title, placeholder) {
  return `<div class="plan-section">
    <div class="plan-section-title">📋 ${title}</div>
    <textarea class="plan-textarea" id="plan-${id}" placeholder="${placeholder}" oninput="updatePlanQuality()">${wizardData['plan_'+id]||''}</textarea>
  </div>`;
}

window.updatePlanQuality = function() {
  const sections = ['mercat','competencia','producte','marketing','finances'];
  let totalChars = 0;
  sections.forEach(s => {
    const el = document.getElementById('plan-' + s);
    if (el) { wizardData['plan_' + s] = el.value; totalChars += el.value.length; }
  });
  const quality = Math.min(100, Math.round(totalChars / 20));
  wizardData.planQuality = quality;
  const disp = document.getElementById('plan-quality-display');
  if (disp) {
    const stars = quality >= 80 ? '⭐⭐⭐⭐⭐' : quality >= 60 ? '⭐⭐⭐⭐' : quality >= 40 ? '⭐⭐⭐' : quality >= 20 ? '⭐⭐' : '⭐';
    disp.textContent = `Qualitat del pla: ${stars} (${quality}%)`;
    disp.style.color = quality >= 60 ? 'var(--green)' : quality >= 30 ? 'var(--gold)' : 'var(--red)';
  }
};

function renderStep_Finance() {
  const forma = FORMES_JURIDIQUES.find(f => f.id === wizardData.legalForm) || FORMES_JURIDIQUES[1];
  const planQ = wizardData.planQuality || 0;
  const interestBase = planQ >= 70 ? 3.5 : planQ >= 40 ? 5.5 : 8.0;
  const maxLoan = planQ >= 70 ? 200000 : planQ >= 40 ? 100000 : 50000;
  wizardData.estimatedInterest = interestBase;
  wizardData.maxLoanAmount = maxLoan;
  document.getElementById('wizard-panel').innerHTML = `
    <div class="wizard-title">Finançament</div>
    <div class="wizard-subtitle">Necessites capital per posar en marxa l'empresa. Combina capital propi i finançament bancari.</div>
    <div class="bank-card">
      <div class="bank-officer">
        <div class="officer-avatar">🏦</div>
        <div>
          <div class="officer-name">Sr. Martínez — Director Banca Empreses</div>
          <div class="officer-title">CaixaBank, Oficina Granollers</div>
        </div>
      </div>
      <div class="officer-speech">"Hem revisat el vostre pla de negoci. Basant-nos en la qualitat (${planQ}%), us podem oferir un préstec de fins a <strong>${maxLoan.toLocaleString('ca')}€</strong> a un tipus del <strong>${interestBase}% anual</strong>. Necessitarem avals i documentació acreditativa."</div>
    </div>
    <div class="form-row">
      <div class="form-group2"><label>Capital propi (€) — Mínim ${forma.capital.toLocaleString('ca')}€</label>
        <input class="form-input" type="number" id="wiz-own-capital" value="${Math.max(forma.capital, wizardData.ownCapital||forma.capital)}" oninput="updateApproval()"></div>
      <div class="form-group2"><label>Sol·licitud crèdit bancari (€) — Màx ${maxLoan.toLocaleString('ca')}€</label>
        <input class="form-input" type="number" id="wiz-loan-amount" value="${wizardData.loanAmount||20000}" oninput="updateApproval()"></div>
    </div>
    <div class="form-group2"><label>Aval: propietat com a garantia</label>
      <select class="form-select" id="wiz-aval" onchange="updateApproval()">
        <option value="0">Cap aval</option>
        <option value="1">Pares/tutors com a avaladors</option>
        <option value="2">Pòlissa d'assegurança vida</option>
        <option value="3">Propietat immobiliària</option>
      </select></div>
    <div id="approval-section">
      <div style="font-size:12px;color:var(--text2);margin-bottom:6px">Probabilitat aprovació:</div>
      <div class="approval-bar"><div class="approval-fill" id="approval-fill" style="width:50%"></div></div>
      <div id="approval-text" style="font-size:12px;color:var(--text2)">Calculant...</div>
    </div>
    <div class="info-box">💡 <strong>Capital total disponible:</strong> <span id="total-capital" class="tstat-v">—</span></div>
    <div class="wizard-nav">
      <button class="btn-prev" onclick="wizardPrev()">← Enrere</button>
      <button class="btn-next" onclick="wizardNext()">Continuar →</button>
    </div>`;
  updateApproval();
}

window.updateApproval = function() {
  const own = parseFloat(document.getElementById('wiz-own-capital')?.value||0);
  const loan = parseFloat(document.getElementById('wiz-loan-amount')?.value||0);
  const aval = parseInt(document.getElementById('wiz-aval')?.value||0);
  const planQ = wizardData.planQuality || 0;
  let prob = (planQ * 0.4) + (aval * 15) + (own > 10000 ? 20 : own/1000);
  prob = Math.min(95, Math.max(5, prob));
  wizardData.loanApprovalProb = prob;
  const fill = document.getElementById('approval-fill');
  const text = document.getElementById('approval-text');
  const total = document.getElementById('total-capital');
  if (fill) fill.style.width = prob + '%';
  if (text) text.textContent = `${prob.toFixed(0)}% probabilitat d'aprovació. ${prob >= 70 ? '✅ Molt bona!' : prob >= 40 ? '⚠️ Acceptable' : '❌ Cal millorar el pla o aportar avals'}`;
  if (text) text.style.color = prob >= 70 ? 'var(--green)' : prob >= 40 ? 'var(--gold)' : 'var(--red)';
  if (total) total.textContent = (own + loan).toLocaleString('ca') + '€';
};

function renderStep_Const() {
  const forma = FORMES_JURIDIQUES.find(f => f.id === wizardData.legalForm) || FORMES_JURIDIQUES[1];
  const steps = [
    {icon:'✅',step:'Denominació social',desc:'Sol·licitud al Registre Mercantil Central. 3-5 dies hàbils.',cost:20,done:true},
    {icon:'📝',step:'Estatuts socials',desc:'Notari: redacció d\'estatuts i escriptura de constitució.',cost:400,done:false},
    {icon:'🏛️',step:'Registre Mercantil',desc:'Inscripció de l\'empresa al Registre Mercantil Provincial.',cost:150,done:false},
    {icon:'🔢',step:'NIF provisional (Agència Tributària)',desc:'Sol·licitar el CIF/NIF de l\'empresa. Tràmit gratuït.',cost:0,done:false},
    {icon:'💼',step:'IAE (Impost Activitats Econòmiques)',desc:'Alta al padró municipal. Gratuït fins a 1M€ facturació.',cost:0,done:false},
    {icon:'🏢',step:'Alta Seguretat Social (compte cotització)',desc:'Alta com a empresa a la TGSS per poder contractar.',cost:0,done:false},
    {icon:'📋',step:'Llicència d\'obertura (Ajuntament)',desc:'Necessària per establiments i locals.',cost:250,done:false},
  ];
  const totalCost = steps.reduce((s,st) => s + st.cost, 0) + forma.cost_const;
  document.getElementById('wizard-panel').innerHTML = `
    <div class="wizard-title">Constitució de l'empresa</div>
    <div class="wizard-subtitle">Tràmits legals necessaris per constituir la <strong style="color:var(--accent)">${wizardData.companyName}</strong> com a <strong style="color:var(--accent)">${forma.name}</strong>.</div>
    <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:16px">
      ${steps.map(st => `
        <div style="display:flex;align-items:center;gap:12px;padding:10px 14px;background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:10px">
          <div style="font-size:22px">${st.icon}</div>
          <div style="flex:1">
            <div style="font-size:13px;font-weight:700;color:var(--text)">${st.step}</div>
            <div style="font-size:11px;color:var(--text2);margin-top:2px">${st.desc}</div>
          </div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:12px;color:${st.cost===0?'var(--green)':'var(--gold)'}">${st.cost===0?'Gratuït':st.cost+'€'}</div>
        </div>`).join('')}
    </div>
    <div class="warn-box">⚠️ <strong>Cost total aproximat de constitució:</strong> ${totalCost.toLocaleString('ca')}€ (s'extraurà del capital inicial)</div>
    <div class="info-box">ℹ️ El temps total de constitució és d'aproximadament <strong>2-4 setmanes</strong>. Durant aquest temps no podràs operar.</div>
    <div class="wizard-nav">
      <button class="btn-prev" onclick="wizardPrev()">← Enrere</button>
      <button class="btn-next" onclick="function(){wizardData.constCost=${totalCost};wizardNext();}(); wizardData.constCost=${totalCost}; wizardNext()">Finalitzar tràmits →</button>
    </div>`;
}

function renderStep_Location() {
  document.getElementById('wizard-panel').innerHTML = `
    <div class="wizard-title">Instal·lacions</div>
    <div class="wizard-subtitle">On instal·laràs la teva empresa? Escull entre llogar o comprar un local.</div>
    <div class="form-row">
      <div class="form-group2"><label>Municipi</label>
        <select class="form-select" id="wiz-muni">
          <option value="Granollers">Granollers</option>
          <option value="Sabadell">Sabadell</option>
          <option value="Terrassa">Terrassa</option>
          <option value="Mollet del Vallès">Mollet del Vallès</option>
          <option value="Cerdanyola del Vallès">Cerdanyola del Vallès</option>
          <option value="Rubí">Rubí</option>
          <option value="Sant Cugat">Sant Cugat del Vallès</option>
          <option value="La Garriga">La Garriga</option>
          <option value="Cardedeu">Cardedeu</option>
        </select></div>
      <div class="form-group2"><label>Superfície (m²)</label>
        <input class="form-input" type="number" id="wiz-surface" value="${wizardData.surface||100}" oninput="updateRent()"></div>
    </div>
    <div class="form-row">
      <div class="form-group2"><label>Règim</label>
        <select class="form-select" id="wiz-regime" onchange="updateRent()">
          <option value="lloguer">Lloguer</option>
          <option value="compra">Compra</option>
        </select></div>
      <div class="form-group2" id="rent-display">
        <label>Cost estimat</label>
        <div id="rent-val" style="padding:12px 14px;background:rgba(255,255,255,.05);border:1px solid var(--border2);border-radius:8px;font-family:'JetBrains Mono',monospace;font-size:14px;color:var(--gold)">—</div>
      </div>
    </div>
    <div class="info-box" id="location-info">Selecciona les opcions per veure el cost estimat.</div>
    <div class="wizard-nav">
      <button class="btn-prev" onclick="wizardPrev()">← Enrere</button>
      <button class="btn-next" onclick="saveLocation(); wizardNext()">Continuar →</button>
    </div>`;
  updateRent();
}

window.updateRent = function() {
  const surface = parseInt(document.getElementById('wiz-surface')?.value||100);
  const regime = document.getElementById('wiz-regime')?.value||'lloguer';
  const muni = document.getElementById('wiz-muni')?.value||'Granollers';
  const pricePerM2 = {Granollers:8, Sabadell:9, Terrassa:8.5, 'Mollet del Vallès':7, 'Cerdanyola del Vallès':10, Rubí:7.5, 'Sant Cugat':12, 'La Garriga':6, Cardedeu:6.5};
  const priceM2 = pricePerM2[muni] || 8;
  let cost, label;
  if (regime === 'lloguer') {
    cost = surface * priceM2;
    label = `${cost.toLocaleString('ca')}€/mes (${priceM2}€/m²)`;
  } else {
    cost = surface * priceM2 * 120;
    label = `${cost.toLocaleString('ca')}€ (compra, ${(priceM2*120).toFixed(0)}€/m²)`;
  }
  wizardData.locationCost = cost; wizardData.locationRegime = regime; wizardData.locationSurface = surface; wizardData.locationMuni = muni;
  const el = document.getElementById('rent-val');
  if (el) el.textContent = label;
  const info = document.getElementById('location-info');
  if (info) info.innerHTML = regime === 'lloguer' ? `📍 <strong>${muni}</strong>: Local de ${surface}m² en lloguer. Despesa mensual fixa de <strong>${cost.toLocaleString('ca')}€</strong>.` : `📍 <strong>${muni}</strong>: Local de ${surface}m² en propietat. Inversió de <strong>${cost.toLocaleString('ca')}€</strong> (possiblement amb hipoteca).`;
};

window.saveLocation = function() {
  wizardData.locationMuni = document.getElementById('wiz-muni')?.value;
};

function renderStep_Staff() {
  document.getElementById('wizard-panel').innerHTML = `
    <div class="wizard-title">Personal inicial</div>
    <div class="wizard-subtitle">Quants treballadors necessites per iniciar l'activitat? Podràs contractar més endavant.</div>
    <div class="form-row">
      <div class="form-group2"><label>Comercials / Vendes</label>
        <input class="form-input" type="number" id="wiz-sales" value="${wizardData.initSales||1}" min="0" max="10" oninput="updateStaffCost()"></div>
      <div class="form-group2"><label>Producció / Operaris</label>
        <input class="form-input" type="number" id="wiz-ops" value="${wizardData.initOps||2}" min="0" max="20" oninput="updateStaffCost()"></div>
    </div>
    <div class="form-row">
      <div class="form-group2"><label>Administració</label>
        <input class="form-input" type="number" id="wiz-admin" value="${wizardData.initAdmin||1}" min="0" max="5" oninput="updateStaffCost()"></div>
      <div class="form-group2"><label>Tècnics especialistes</label>
        <input class="form-input" type="number" id="wiz-tech" value="${wizardData.initTech||0}" min="0" max="10" oninput="updateStaffCost()"></div>
    </div>
    <div class="info-box" id="staff-cost-info">Calculant cost de nòmines...</div>
    <div class="warn-box">⚠️ Recorda que a més del sou brut, l'empresa paga la Seguretat Social (~30% del sou). El cost total per treballador és superior al sou indicat.</div>
    <div class="wizard-nav">
      <button class="btn-prev" onclick="wizardPrev()">← Enrere</button>
      <button class="btn-next" onclick="finishWizard()" style="background:var(--green)">🚀 Crear empresa!</button>
    </div>`;
  updateStaffCost();
}

window.updateStaffCost = function() {
  const sales = parseInt(document.getElementById('wiz-sales')?.value||0);
  const ops = parseInt(document.getElementById('wiz-ops')?.value||0);
  const admin = parseInt(document.getElementById('wiz-admin')?.value||0);
  const tech = parseInt(document.getElementById('wiz-tech')?.value||0);
  const costSales = sales * 1800, costOps = ops * 1400, costAdmin = admin * 1600, costTech = tech * 2200;
  const total = costSales + costOps + costAdmin + costTech;
  const totalSS = Math.round(total * 1.30);
  wizardData.initSales = sales; wizardData.initOps = ops; wizardData.initAdmin = admin; wizardData.initTech = tech;
  wizardData.monthlySalaryCost = totalSS;
  const el = document.getElementById('staff-cost-info');
  if (el) el.innerHTML = `👥 <strong>${sales+ops+admin+tech} treballadors</strong>. Cost brut mensual: ${total.toLocaleString('ca')}€. Cost real amb SS: <strong style="color:var(--red)">${totalSS.toLocaleString('ca')}€/mes</strong>.`;
};

async function finishWizard() {
  const forma = FORMES_JURIDIQUES.find(f => f.id === wizardData.legalForm) || FORMES_JURIDIQUES[1];
  const ownCapital = wizardData.ownCapital || forma.capital;
  const loanAmount = wizardData.loanAmount || 0;
  const approved = Math.random() * 100 < (wizardData.loanApprovalProb || 60);
  const actualLoan = approved ? loanAmount : 0;
  const initialCash = ownCapital + actualLoan - (wizardData.constCost || forma.cost_const);
  const monthlyRent = wizardData.locationRegime === 'lloguer' ? (wizardData.locationCost || 800) : 0;
  const sectorData = SECTORS.find(s => s.id === wizardData.sector) || SECTORS[0];

  // Build employees
  const initEmps = generateInitialEmployees(wizardData);
  const initMachines = [{...MACHINES[0], id: 'machine_' + Date.now()}];

  G.gameData.mode = 'create';
  G.gameData.prestigi = 5;
  G.gameData.company = {
    name: wizardData.companyName,
    sector: wizardData.sector,
    sectorData,
    legalForm: wizardData.legalForm,
    legalFormName: forma.name,
    nif: 'B' + Math.floor(10000000 + Math.random()*89999999),
    iae: getIAE(wizardData.sector),
    founded: `${G.gameData.week}/2024`,
    municipality: wizardData.locationMuni || 'Granollers',
    surface: wizardData.locationSurface || 100,
    regime: wizardData.locationRegime || 'lloguer',
    monthlyRent,
    description: wizardData.desc || '',
  };
  G.gameData.finances.cash = Math.max(0, initialCash);
  G.gameData.finances.actiu.tresoreria = Math.max(0, initialCash);
  G.gameData.finances.passiu.capital = ownCapital;
  G.gameData.employees = initEmps;
  G.gameData.machines = initMachines;
  G.gameData.mktBudget = Math.floor(initialCash * 0.05);

  if (actualLoan > 0) {
    const interest = wizardData.estimatedInterest || 5.5;
    const years = 7;
    const monthlyPayment = Math.round(actualLoan * (interest/100/12) / (1 - Math.pow(1+interest/100/12, -years*12)));
    G.gameData.finances.loans.push({
      id: 'loan_' + Date.now(), amount: actualLoan, remaining: actualLoan,
      interest, years, monthlyPayment, startWeek: G.gameData.week,
    });
    G.gameData.finances.passiu.deutes_llarg = actualLoan;
  }

  G.gameData.notifications.push({
    id: Date.now(), icon: '🎉', title: 'Empresa constituïda!',
    desc: `${wizardData.companyName} (${forma.name}) ha estat creada correctament. ${approved ? `Crèdit de ${actualLoan.toLocaleString('ca')}€ aprovat!` : 'El crèdit no ha estat aprovat.'}`,
    time: 'Ara', urgent: false, read: false,
  });

  await saveGameData();
  showActiveGame();
  renderDashboard(); renderFinances(); renderHR(); renderProduction(); renderMarketing();
  showEventToast('🎉', 'Empresa creada!', `${wizardData.companyName} ha iniciat activitats. Capital: ${initialCash.toLocaleString('ca')}€`, true);
}

function generateInitialEmployees(wd) {
  const emps = [];
  const names = ['Anna García','Jordi Puig','Maria López','Joan Fernández','Laura Martí','Pere Sánchez','Núria Ros','Marc Vidal'];
  let ni = 0;
  const addEmp = (dept, role, salary) => {
    emps.push({id:'emp_'+Date.now()+'_'+ni, name:names[ni%names.length], dept, role, salary, morale:75, seniority:0, avatar:'👤'});
    ni++;
  };
  for (let i=0;i<(wd.initSales||1);i++) addEmp('vendes','Comercial',1800);
  for (let i=0;i<(wd.initOps||2);i++) addEmp('produccio','Operari/a',1400);
  for (let i=0;i<(wd.initAdmin||1);i++) addEmp('admin','Administratiu/va',1600);
  for (let i=0;i<(wd.initTech||0);i++) addEmp('tecnic','Tècnic/a',2200);
  return emps;
}

function getIAE(sector) {
  const iaeMap = {alimentacio:'6411',tecnologia:'6221',construccio:'5011',comerç:'6111',logistica:'7221',turisme:'6712',salut:'9411',educacio:'9311',moda:'4531',quimica:'2521'};
  return iaeMap[sector] || '6111';
}

// ==================== HIRED MODE ====================
function showHiredMode() {
  document.getElementById('setup-init').style.display = 'none';
  document.getElementById('wizard-area').style.display = 'none';
  document.getElementById('hired-area').style.display = '';
  document.getElementById('active-company').style.display = 'none';
  document.getElementById('hired-prestigi').textContent = G.gameData.prestigi || 0;
  renderJobOffers();
}

function renderJobOffers() {
  const prest = G.gameData.prestigi || 0;
  let available = VALLES_EMPRESES.filter(e => {
    if (prest < 10) return e.size === 'small';
    if (prest < 25) return e.size !== 'corp';
    return true;
  });
  available = available.sort(() => Math.random() - 0.5).slice(0, 6);
  document.getElementById('offers-grid').innerHTML = available.map(e => {
    const sizeLabel = {small:'Petita',medium:'Mitjana',large:'Gran',corp:'Corporació'}[e.size];
    const sectorD = SECTORS.find(s => s.id === e.sector) || SECTORS[0];
    const salary = e.size === 'small' ? 2800 : e.size === 'medium' ? 4200 : e.size === 'large' ? 6500 : 9000;
    const roles = JOBS_BY_PRESTIGI.find(j => prest >= j.minPrest && prest < j.maxPrest) || JOBS_BY_PRESTIGI[0];
    const role = roles.roles[Math.floor(Math.random()*roles.roles.length)];
    return `
      <div class="offer-card">
        <div class="offer-top">
          <div>
            <div class="offer-company">${sectorD.icon} ${e.name}</div>
            <div class="offer-sector">${sectorD.name} · ${e.muni}</div>
            <div style="margin-top:6px;font-size:12px;font-weight:600;color:var(--accent)">${role}</div>
          </div>
          <div class="offer-size-badge ${e.size}">${sizeLabel}</div>
        </div>
        <div class="offer-salary">💰 ${salary.toLocaleString('ca')}€/any</div>
        <div class="offer-prestigi">Facturació: ~${(e.fact/1000000).toFixed(1)}M€ · ${e.emp} empleats</div>
        <div class="offer-details">
          <span class="offer-tag">📍 ${e.muni}</span>
          <span class="offer-tag">👥 ${e.emp} persones</span>
          <span class="offer-tag">🏭 ${sectorD.sector}</span>
        </div>
        <button class="offer-btn" onclick="acceptOffer(${JSON.stringify(e).replace(/"/g,'&quot;')}, '${role}', ${salary})">Acceptar oferta →</button>
      </div>`;
  }).join('');
}

window.acceptOffer = async function(company, role, salary) {
  const sectorData = SECTORS.find(s => s.id === company.sector) || SECTORS[0];
  G.gameData.mode = 'hired';
  G.gameData.prestigi = (G.gameData.prestigi || 0) + 3;
  G.gameData.company = {
    name: company.name,
    sector: company.sector,
    sectorData,
    legalForm: 'sa',
    legalFormName: 'Societat Anònima',
    nif: 'A' + Math.floor(10000000 + Math.random()*89999999),
    municipality: company.muni,
    myRole: role,
    mySalary: salary,
    totalEmployees: company.emp,
    annualRevenue: company.fact,
    size: company.size,
    surface: company.size === 'small' ? 150 : company.size === 'medium' ? 500 : 2000,
    monthlyRent: company.size === 'small' ? 1200 : company.size === 'medium' ? 4000 : 12000,
    regime: 'lloguer',
  };
  G.gameData.finances.cash = company.fact * 0.1; // 10% facturació com a cash
  G.gameData.finances.monthly_revenue = company.fact / 12;
  G.gameData.finances.monthly_costs = (company.fact / 12) * 0.78;
  G.gameData.employees = generateHiredEmployees(company);
  G.gameData.notifications.push({
    id: Date.now(), icon: '💼', title: 'Incorporació a l\'empresa!',
    desc: `Has sigut contractat/da com a ${role} a ${company.name}. Sou: ${salary.toLocaleString('ca')}€/any`,
    time: 'Ara', urgent: false, read: false,
  });
  await saveGameData();
  showActiveGame();
  renderDashboard(); renderFinances(); renderHR(); renderMarketing();
  showEventToast('💼', 'Contractat/da!', `Inici com a ${role} a ${company.name}`, true);
};

function generateHiredEmployees(company) {
  const count = Math.min(company.emp, 15);
  const emps = [];
  const names = ['Anna García','Jordi Puig','Maria López','Joan Fernández','Laura Martí','Pere Sánchez','Núria Ros','Marc Vidal','Ester Mas','David Font','Carla Rius','Àlex Torres','Marta Bosch','Pau Serrat','Silvia Mir'];
  const roles = ['Comercial','Tècnic/a','Administratiu/va','Operari/a','Cap de Secció','Comptable','Logística'];
  for (let i=0;i<count;i++) {
    emps.push({
      id:'emp_'+i, name:names[i%names.length], dept: i%2===0?'vendes':'produccio',
      role:roles[i%roles.length], salary: 1400 + Math.floor(Math.random()*1400),
      morale: 60 + Math.floor(Math.random()*35), seniority: Math.floor(Math.random()*8), avatar:'👤'
    });
  }
  return emps;
}

// ==================== RENDER ACTIVE COMPANY ====================
function renderActiveCompany() {
  const c = G.gameData.company;
  if (!c) return;
  document.getElementById('company-main-icon').textContent = c.sectorData?.icon || '🏢';
  document.getElementById('company-main-name').textContent = c.name;
  document.getElementById('company-main-info').textContent = `${c.legalFormName || ''} · ${c.municipality || ''} · ${c.sectorData?.name || ''}`;
  const legal = document.getElementById('company-legal-info');
  if (legal) legal.innerHTML = [
    `NIF/CIF: <strong style="color:var(--text)">${c.nif||'—'}</strong>`,
    `IAE: <strong style="color:var(--text)">${c.iae||'—'}</strong>`,
    `Forma: <strong style="color:var(--text)">${c.legalFormName||'—'}</strong>`,
    `Municipi: <strong style="color:var(--text)">${c.municipality||'—'}</strong>`,
    `Superfície: <strong style="color:var(--text)">${c.surface||0}m²</strong>`,
    `Règim: <strong style="color:var(--text)">${c.regime||'—'}</strong>`,
  ].join('<br>');
  const loans = G.gameData.finances.loans || [];
  const loansEl = document.getElementById('loans-list');
  if (loansEl) loansEl.innerHTML = loans.length === 0 ? '<div style="color:var(--text2);font-size:13px">Sense préstecs actius.</div>' : loans.map(l => `
    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:12px">
      <span style="color:var(--text2)">Préstec bancari</span>
      <span style="color:var(--gold);font-family:\'JetBrains Mono\',monospace">${l.remaining.toLocaleString('ca')}€ pendent</span>
      <span style="color:var(--text2)">${l.interest}% · ${l.monthlyPayment.toLocaleString('ca')}€/mes</span>
    </div>`).join('');
}

// ==================== DASHBOARD ====================
function renderDashboard() {
  const gd = G.gameData;
  if (!gd) return;
  const f = gd.finances;
  const c = gd.company;

  // Banner
  if (c) {
    document.getElementById('company-banner').style.display = '';
    document.getElementById('banner-icon').textContent = c.sectorData?.icon || '🏢';
    document.getElementById('banner-title').textContent = c.name;
    document.getElementById('banner-desc').textContent = c.legalFormName + ' · ' + c.municipality + ' · Setmana ' + gd.week + ' · Any ' + gd.year;
  } else {
    document.getElementById('company-banner').style.display = 'none';
  }

  const cash = f.cash || 0;
  const rev = f.monthly_revenue || 0;
  const costs = f.monthly_costs || 0;
  const result = rev - costs;

  document.getElementById('kpi-cash').textContent = cash.toLocaleString('ca') + '€';
  document.getElementById('kpi-cash').className = 'kpi-val ' + (cash >= 0 ? '' : 'negative');
  document.getElementById('kpi-cash-ch').textContent = cash >= 10000 ? '✅ Situació saludable' : cash >= 0 ? '⚠️ Vigilar liquiditat' : '❌ Tresoreria negativa';
  document.getElementById('kpi-rev').textContent = rev.toLocaleString('ca') + '€';
  document.getElementById('kpi-costs').textContent = costs.toLocaleString('ca') + '€';
  document.getElementById('kpi-prest').textContent = gd.prestigi || 0;
  document.getElementById('kpi-result').textContent = result.toLocaleString('ca') + '€';
  document.getElementById('kpi-result').className = 'kpi-val ' + (result >= 0 ? 'positive' : 'negative');

  // Chart
  const history = f.revenue_history || [];
  const bars = document.getElementById('chart-bars');
  if (bars) {
    const max = Math.max(...history.map(h => Math.abs(h.rev)), 1);
    bars.innerHTML = history.slice(-12).map(h => {
      const pct = Math.max(4, Math.round((Math.abs(h.rev) / max) * 100));
      return `<div class="chart-bar ${h.rev < 0 ? 'negative' : ''}" style="height:${pct}%;opacity:.7" title="S${h.week}: ${h.rev.toLocaleString('ca')}€"></div>`;
    }).join('') || '<div style="color:var(--text3);font-size:12px;padding:10px">Sense dades encara</div>';
  }

  // Notifications
  const notifs = gd.notifications || [];
  document.getElementById('notif-list').innerHTML = notifs.slice(-5).reverse().map(n => `
    <div class="notif-item ${n.urgent?'urgent':''}" onclick="markRead('${n.id}')">
      <div class="notif-icon">${n.icon||'📋'}</div>
      <div class="notif-body">
        <div class="notif-title">${n.title}</div>
        <div class="notif-desc">${n.desc}</div>
      </div>
      <div class="notif-time">${n.time||''}</div>
    </div>`).join('') || '<div style="color:var(--text3);font-size:12px;text-align:center;padding:20px">Sense notificacions</div>';

  // Departments
  const depts = [
    {icon:'💰',name:'Finances',status: cash >= 0 ? 'ok' : 'bad', statusTxt: cash >= 0 ? 'Estable' : 'Crítica'},
    {icon:'👥',name:'RRHH',status:'ok',statusTxt:`${gd.employees?.length||0} persones`},
    {icon:'🏭',name:'Producció',status:'ok',statusTxt:`${gd.machines?.length||0} màquines`},
    {icon:'📦',name:'Vendes',status: rev > 0 ? 'ok' : 'warn', statusTxt: rev > 0 ? `${rev.toLocaleString('ca')}€/mes` : 'Sense vendes'},
    {icon:'📣',name:'Màrqueting',status:'ok',statusTxt:'Actiu'},
    {icon:'🏗️',name:'Instal·lacions',status:'ok',statusTxt: c ? c.municipality : '—'},
  ];
  document.getElementById('dept-grid').innerHTML = depts.map(d => `
    <div class="dept-card" onclick="showTab('${d.name==='Finances'?'finances':d.name==='RRHH'?'hr':d.name==='Producció'?'production':d.name==='Vendes'?'sales':d.name==='Màrqueting'?'marketing':'dashboard'}')">
      <div class="dept-icon">${d.icon}</div>
      <div class="dept-name">${d.name}</div>
      <div class="dept-status ${d.status}">${d.statusTxt}</div>
    </div>`).join('');
}

// ==================== FINANCES ====================
function renderFinances() {
  const gd = G.gameData;
  if (!gd) return;
  const f = gd.finances;
  const rev = f.monthly_revenue || 0;
  const costs = f.monthly_costs || 0;
  const result = rev - costs;
  document.getElementById('fin-period').textContent = `Any ${gd.year} · Setmana ${gd.week}`;

  // P&G
  const loans = f.loans || [];
  const loanPayments = loans.reduce((s, l) => s + (l.monthlyPayment || 0), 0);
  const salaries = (gd.employees || []).reduce((s, e) => s + (e.salary || 0) * 1.3, 0);
  const rent = gd.company?.monthlyRent || 0;
  const mktCost = gd.mktBudget || 0;
  const otherCosts = costs - salaries - rent - mktCost - loanPayments;

  document.getElementById('pyg-table').innerHTML = `
    <div class="bal-row"><div class="bal-row-label">Ingressos d'explotació</div><div class="bal-row-val" style="color:var(--green)">+${rev.toLocaleString('ca')}€</div></div>
    <div class="bal-row"><div class="bal-row-label">Nòmines (SS inclosa)</div><div class="bal-row-val" style="color:var(--red)">-${salaries.toFixed(0).toLocaleString('ca')}€</div></div>
    <div class="bal-row"><div class="bal-row-label">Lloguer instal·lacions</div><div class="bal-row-val" style="color:var(--red)">-${rent.toLocaleString('ca')}€</div></div>
    <div class="bal-row"><div class="bal-row-label">Màrqueting i publicitat</div><div class="bal-row-val" style="color:var(--red)">-${mktCost.toLocaleString('ca')}€</div></div>
    <div class="bal-row"><div class="bal-row-label">Quota préstecs</div><div class="bal-row-val" style="color:var(--red)">-${loanPayments.toLocaleString('ca')}€</div></div>
    <div class="bal-row"><div class="bal-row-label">Altres despeses</div><div class="bal-row-val" style="color:var(--red)">-${Math.max(0,otherCosts).toFixed(0)}€</div></div>
    <div class="bal-row total"><div class="bal-row-label">Resultat mensual</div><div class="bal-row-val" style="color:${result>=0?'var(--green)':'var(--red)'}">${result>=0?'+':''}${result.toFixed(0)}€</div></div>`;

  document.getElementById('treasury-info').innerHTML = `
    <div class="bal-row"><div class="bal-row-label">Tresoreria actual</div><div class="bal-row-val" style="color:var(--gold)">${(f.cash||0).toLocaleString('ca')}€</div></div>
    <div class="bal-row"><div class="bal-row-label">Fons de maniobra</div><div class="bal-row-val" style="color:${((f.actiu?.existencies||0)+(f.actiu?.clients||0)+(f.cash||0))-(f.passiu?.deutes_curt||0) >= 0 ? 'var(--green)':'var(--red)'}">${(((f.actiu?.existencies||0)+(f.actiu?.clients||0)+(f.cash||0))-(f.passiu?.deutes_curt||0)).toLocaleString('ca')}€</div></div>
    <div class="bal-row"><div class="bal-row-label">Ràtio liquiditat</div><div class="bal-row-val">${(f.passiu?.deutes_curt||0) > 0 ? (((f.actiu?.existencies||0)+(f.cash||0))/(f.passiu?.deutes_curt||1)).toFixed(2) : '∞'}</div></div>
    <div class="bal-row"><div class="bal-row-label">Deute total</div><div class="bal-row-val" style="color:var(--red)">${((f.passiu?.deutes_llarg||0)+(f.passiu?.deutes_curt||0)).toLocaleString('ca')}€</div></div>`;

  // Balance sheet
  const actiu = f.actiu || {};
  const passiu = f.passiu || {};
  const totalActiu = (actiu.immobilitzat||0) + (actiu.existencies||0) + (f.cash||0) + (actiu.clients||0);
  const totalPassiu = (passiu.capital||0) + (passiu.reserves||0) + (passiu.deutes_llarg||0) + (passiu.deutes_curt||0);

  document.getElementById('actiu-rows').innerHTML = `
    <div class="bal-row"><div class="bal-row-label">Immobilitzat (màquines, local)</div><div class="bal-row-val">${(actiu.immobilitzat||0).toLocaleString('ca')}€</div></div>
    <div class="bal-row"><div class="bal-row-label">Existències</div><div class="bal-row-val">${(actiu.existencies||0).toLocaleString('ca')}€</div></div>
    <div class="bal-row"><div class="bal-row-label">Clients (saldo pendent)</div><div class="bal-row-val">${(actiu.clients||0).toLocaleString('ca')}€</div></div>
    <div class="bal-row"><div class="bal-row-label">Tresoreria</div><div class="bal-row-val" style="color:var(--gold)">${(f.cash||0).toLocaleString('ca')}€</div></div>
    <div class="bal-row total"><div class="bal-row-label">TOTAL ACTIU</div><div class="bal-row-val">${totalActiu.toLocaleString('ca')}€</div></div>`;

  document.getElementById('passiu-rows').innerHTML = `
    <div class="bal-row"><div class="bal-row-label">Capital social</div><div class="bal-row-val">${(passiu.capital||0).toLocaleString('ca')}€</div></div>
    <div class="bal-row"><div class="bal-row-label">Reserves</div><div class="bal-row-val">${(passiu.reserves||0).toLocaleString('ca')}€</div></div>
    <div class="bal-row"><div class="bal-row-label">Deutes llarg termini</div><div class="bal-row-val">${(passiu.deutes_llarg||0).toLocaleString('ca')}€</div></div>
    <div class="bal-row"><div class="bal-row-label">Deutes curt termini</div><div class="bal-row-val">${(passiu.deutes_curt||0).toLocaleString('ca')}€</div></div>
    <div class="bal-row"><div class="bal-row-label">Proveïdors</div><div class="bal-row-val">${(passiu.proveidors||0).toLocaleString('ca')}€</div></div>
    <div class="bal-row total"><div class="bal-row-label">TOTAL PASSIU + PN</div><div class="bal-row-val">${totalPassiu.toLocaleString('ca')}€</div></div>`;

  // Ratios
  const ratios = [
    {name:'Rendibilitat econòmica',val: totalActiu > 0 ? ((result*12/totalActiu)*100).toFixed(1)+'%' : 'N/D', good: result > 0},
    {name:'Ràtio d\'endeutament',val: (passiu.capital||0) > 0 ? (((passiu.deutes_llarg||0)+(passiu.deutes_curt||0))/(passiu.capital||1)).toFixed(2) : 'N/D', good: ((passiu.deutes_llarg||0)+(passiu.deutes_curt||0)) < (passiu.capital||0)*2},
    {name:'Fons de maniobra',val: (((actiu.existencies||0)+(f.cash||0))-(passiu.deutes_curt||0)).toLocaleString('ca')+'€', good: ((actiu.existencies||0)+(f.cash||0)) > (passiu.deutes_curt||0)},
    {name:'Marge comercial',val: rev > 0 ? ((result/rev)*100).toFixed(1)+'%' : 'N/D', good: result > 0},
    {name:'Liquiditat',val: (passiu.deutes_curt||0) > 0 ? ((f.cash||0)/(passiu.deutes_curt||1)).toFixed(2) : '∞', good: (f.cash||0) >= (passiu.deutes_curt||0)},
    {name:'Rotació actiu',val: totalActiu > 0 ? ((rev*12/totalActiu)).toFixed(2)+'x' : 'N/D', good: rev > 0},
  ];
  document.getElementById('ratios-grid').innerHTML = ratios.map(r => `
    <div class="report-kpi">
      <div class="report-kpi-val" style="color:${r.good?'var(--green)':'var(--red)'};font-size:18px">${r.val}</div>
      <div class="report-kpi-label">${r.name}</div>
    </div>`).join('');
}

// ==================== HR ====================
function renderHR() {
  const emps = G.gameData.employees || [];
  const totalSalary = emps.reduce((s, e) => s + (e.salary || 0) * 1.3, 0);
  const moraleAvg = emps.length > 0 ? Math.round(emps.reduce((s, e) => s + (e.morale || 60), 0) / emps.length) : 0;

  document.getElementById('employees-list').innerHTML = emps.length === 0
    ? '<div style="text-align:center;color:var(--text2);padding:30px;font-size:14px">Sense empleats. Contracta el teu primer treballador!</div>'
    : emps.map(e => {
      const moraleColor = e.morale >= 70 ? 'var(--green)' : e.morale >= 40 ? 'var(--gold)' : 'var(--red)';
      return `
        <div class="emp-card">
          <div class="emp-avatar">${e.avatar||'👤'}</div>
          <div class="emp-info">
            <div class="emp-name">${e.name}</div>
            <div class="emp-role">${e.dept?.toUpperCase()||'—'} · ${e.role} · ${e.seniority||0} anys</div>
            <div class="emp-salary">${e.salary?.toLocaleString('ca')||0}€ bruts/mes</div>
            <div class="emp-morale">
              <div class="morale-bar"><div class="morale-fill" style="width:${e.morale||60}%;background:${moraleColor}"></div></div>
              <span style="font-size:10px;color:${moraleColor}">${e.morale||60}% ànim</span>
            </div>
          </div>
          <div class="emp-actions">
            <button class="emp-btn raise" onclick="raiseEmployee('${e.id}')">💰 Pujada</button>
            <button class="emp-btn fire" onclick="fireEmployee('${e.id}')">❌ Acomiadar</button>
          </div>
        </div>`}).join('');

  document.getElementById('salary-summary').innerHTML = `
    Empleats: <strong style="color:var(--text)">${emps.length}</strong> · 
    Cost mensual total (SS inclosa): <strong style="color:var(--red)">${totalSalary.toFixed(0)}€</strong> · 
    Mora mitjana: <strong style="color:${moraleAvg>=70?'var(--green)':moraleAvg>=40?'var(--gold)':'var(--red)'}">${moraleAvg}%</strong>`;
}

window.fireEmployee = async function(id) {
  if (!confirm('Segur que vols acomiadar aquesta persona? Possible indemnització.')) return;
  const emp = G.gameData.employees.find(e => e.id === id);
  if (!emp) return;
  const indemnity = (emp.salary || 1400) * (emp.seniority || 0) * 0.33;
  G.gameData.employees = G.gameData.employees.filter(e => e.id !== id);
  G.gameData.finances.cash -= indemnity;
  G.gameData.notifications.push({id:Date.now(), icon:'❌', title:'Empleat acomiadat', desc:`${emp.name} — Indemnització: ${indemnity.toFixed(0)}€`, time:'Ara', urgent:false});
  await saveGameData();
  renderHR(); renderDashboard(); renderFinances();
  showToast(`❌ ${emp.name} acomiadat/da. Indemnització: ${indemnity.toFixed(0)}€`);
};

window.raiseEmployee = async function(id) {
  const emp = G.gameData.employees.find(e => e.id === id);
  if (!emp) return;
  const increase = Math.round(emp.salary * 0.05);
  emp.salary += increase; emp.morale = Math.min(100, (emp.morale||60) + 15);
  await saveGameData(); renderHR();
  showToast(`💰 Pujada de ${increase}€/mes a ${emp.name}`);
};

window.openHireModal = function() {
  const roles = [
    {name:'Comercial', dept:'vendes', salary:1800, icon:'📊'},
    {name:'Operari/a', dept:'produccio', salary:1400, icon:'⚙️'},
    {name:'Administratiu/va', dept:'admin', salary:1600, icon:'📋'},
    {name:'Tècnic/a especialista', dept:'tecnic', salary:2400, icon:'🔧'},
    {name:'Cap de vendes', dept:'vendes', salary:3200, icon:'🏆'},
    {name:'Director/a financer/a', dept:'finances', salary:4500, icon:'💰'},
  ];
  const names = ['Pau Ferrer','Laia Costa','Xavi Rovira','Marta Duran','Joan Albà','Carla Prat','Gerard Roca','Ester Solà'];
  const candidates = roles.map((r, i) => ({
    ...r, name: names[i % names.length] + ' ' + String.fromCharCode(65 + i),
    id: 'cand_' + Date.now() + '_' + i, morale: 80 + Math.floor(Math.random()*20)
  }));
  document.getElementById('hire-candidates').innerHTML = candidates.map(c => `
    <div class="offer-card" style="padding:14px">
      <div style="display:flex;align-items:center;gap:12px">
        <span style="font-size:30px">${c.icon}</span>
        <div style="flex:1">
          <div style="font-weight:700;font-size:14px;color:var(--text)">${c.name}</div>
          <div style="font-size:12px;color:var(--text2)">${c.role} · Dept: ${c.dept}</div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--gold);margin-top:4px">${c.salary.toLocaleString('ca')}€/mes bruts</div>
        </div>
        <button class="offer-btn" onclick="hireCandidate(${JSON.stringify(c).replace(/"/g,'&quot;')})" style="width:auto;padding:8px 14px">Contractar</button>
      </div>
    </div>`).join('');
  document.getElementById('hire-modal').style.display = 'flex';
};

window.closeHireModal = function() { document.getElementById('hire-modal').style.display = 'none'; };

window.hireCandidate = async function(c) {
  const newEmp = {id:'emp_'+Date.now(), name:c.name, dept:c.dept, role:c.role, salary:c.salary, morale:c.morale, seniority:0, avatar:'👤'};
  G.gameData.employees.push(newEmp);
  G.gameData.notifications.push({id:Date.now(), icon:'👥', title:'Nou empleat!', desc:`${c.name} s'incorpora com a ${c.role}`, time:'Ara', urgent:false});
  await saveGameData();
  closeHireModal(); renderHR(); renderDashboard();
  showToast(`✅ ${c.name} contractat/da!`);
};

// ==================== PRODUCTION ====================
function renderProduction() {
  const gd = G.gameData;
  if (!gd || !gd.company) {
    document.getElementById('prod-facility-view').innerHTML = '<div style="color:var(--text2);font-size:14px;text-align:center;padding:40px">Crea o incorpora\'t a una empresa primer.</div>';
    return;
  }
  const c = gd.company;
  const machines = gd.machines || [];
  const totalCap = machines.reduce((s, m) => s + (m.capacity || 0), 0);
  const usedCap = Math.min(totalCap, Math.floor(totalCap * 0.7));

  document.getElementById('prod-facility-view').innerHTML = `
    <div class="prod-facility">
      <div class="facility-header">
        <div class="facility-icon">${c.sectorData?.icon || '🏭'}</div>
        <div>
          <div class="facility-name">${c.name}</div>
          <div class="facility-status">Operativa · ${c.municipality}</div>
          <div style="font-size:12px;color:var(--text2);margin-top:2px">${c.surface || 0}m² · ${c.regime || 'lloguer'}</div>
        </div>
      </div>
      <div style="font-size:12px;color:var(--text2);margin-bottom:6px">Capacitat productiva</div>
      <div class="capacity-bar"><div class="capacity-fill" style="width:${totalCap>0?Math.round(usedCap/totalCap*100):0}%"></div></div>
      <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text2);margin-top:4px"><span>Usada: ${usedCap.toLocaleString('ca')} u/setmana</span><span>Total: ${totalCap.toLocaleString('ca')} u/setmana</span></div>
      <div class="machine-grid" style="margin-top:16px">
        ${machines.length === 0 ? '<div style="color:var(--text2);font-size:13px;grid-column:1/-1;text-align:center;padding:20px">Sense maquinària. Compra la teva primera màquina!</div>' :
          machines.map(m => `
          <div class="machine-card">
            <div class="machine-icon">${m.icon||'⚙️'}</div>
            <div class="machine-name">${m.name}</div>
            <div class="machine-detail">${m.capacity?.toLocaleString('ca') || 0} u/setmana</div>
            <div class="machine-health" style="margin-top:8px;justify-content:center;gap:4px">
              <div class="health-dot" style="width:8px;height:8px;border-radius:50%;background:var(--green)"></div>
              <span style="font-size:10px;color:var(--green)">Operativa</span>
            </div>
            <div style="font-size:10px;color:var(--text3);margin-top:4px">Mant: ${m.maintenance?.toLocaleString('ca')||0}€/mes</div>
          </div>`).join('')}
      </div>
    </div>`;

  document.getElementById('machines-shop').innerHTML = MACHINES.map(m => `
    <div class="machine-card" style="cursor:pointer;transition:.2s" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
      <div class="machine-icon">${m.icon}</div>
      <div class="machine-name">${m.name}</div>
      <div class="machine-detail">${m.desc}</div>
      <div style="font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--gold);margin:8px 0">${m.price.toLocaleString('ca')}€</div>
      <div style="font-size:10px;color:var(--text2)">${m.capacity.toLocaleString('ca')} u/setmana</div>
      <button class="emp-btn promote" style="width:100%;margin-top:10px" onclick="buyMachine('${m.id}')">Comprar</button>
    </div>`).join('');

  // Suppliers
  const suppliers = [
    {name:'Matèries primeres Vallès SL',icon:'📦',price:2000,delivery:3,quality:85},
    {name:'Distribucions Granollers SA',icon:'🚛',price:1800,delivery:5,quality:75},
    {name:'Importació Europa Direct',icon:'🌍',price:1500,delivery:14,quality:90},
  ];
  document.getElementById('suppliers-list').innerHTML = suppliers.map(s => `
    <div class="offer-card" style="padding:12px">
      <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
        <span style="font-size:28px">${s.icon}</span>
        <div style="flex:1">
          <div style="font-weight:700;font-size:14px;color:var(--text)">${s.name}</div>
          <div style="font-size:11px;color:var(--text2);margin-top:3px">Preu: ${s.price.toLocaleString('ca')}€/mes · Termini: ${s.delivery} dies · Qualitat: ${s.quality}%</div>
        </div>
        <button class="offer-btn" style="width:auto;padding:8px 14px" onclick="showToast('📦 Acord amb ${s.name} activat!')">Contractar</button>
      </div>
    </div>`).join('');
}

window.buyMachine = async function(machineId) {
  const m = MACHINES.find(m => m.id === machineId);
  if (!m) return;
  if ((G.gameData.finances.cash || 0) < m.price) { showToast('❌ No tens prou tresoreria'); return; }
  G.gameData.finances.cash -= m.price;
  G.gameData.finances.actiu.immobilitzat = (G.gameData.finances.actiu.immobilitzat || 0) + m.price;
  G.gameData.machines.push({...m, id: 'machine_' + Date.now(), health: 100});
  G.gameData.notifications.push({id:Date.now(), icon:'⚙️', title:'Màquina comprada!', desc:`${m.name} instal·lada. Cost: ${m.price.toLocaleString('ca')}€`, time:'Ara', urgent:false});
  await saveGameData();
  renderProduction(); renderFinances(); renderDashboard();
  showToast(`⚙️ ${m.name} instal·lada!`);
};

// ==================== MARKETING ====================
function renderMarketing() {
  const gd = G.gameData;
  if (!gd) return;
  const budget = gd.mktBudget || 0;
  document.getElementById('mkt-budget').textContent = budget.toLocaleString('ca') + '€';
  const channels = gd.marketing?.channels || {};

  document.getElementById('mkt-channels').innerHTML = MARKETING_CHANNELS.map(ch => {
    const spent = channels[ch.id] || 0;
    const reach = Math.round(spent * ch.reach_mult);
    return `
      <div class="channel-card">
        <div class="channel-header">
          <span class="channel-icon">${ch.icon}</span>
          <div><div class="channel-name">${ch.name}</div><div class="channel-cost">${ch.desc}</div></div>
        </div>
        <div class="channel-slider-wrap">
          <input type="range" class="channel-slider" min="0" max="${ch.cost_per*10}" step="${ch.cost_per}" value="${spent}" 
            oninput="updateChannel('${ch.id}', this.value)">
          <div class="channel-val">${spent.toLocaleString('ca')}€</div>
        </div>
        <div class="reach-meter"><div class="reach-fill" style="width:${Math.min(100, reach/50)}%"></div></div>
        <div style="font-size:10px;color:var(--text2);margin-top:4px">Abast estimat: ~${reach.toLocaleString('ca')} persones</div>
      </div>`;
  }).join('');

  const activeSponsors = gd.marketing?.sponsors || [];
  document.getElementById('sponsors-list').innerHTML = SPONSORS.map(sp => {
    const isActive = activeSponsors.includes(sp.id);
    const canAfford = (G.gameData.finances.cash || 0) >= sp.cost;
    const meetsReq = (G.gameData.prestigi || 0) >= sp.prestigi_req;
    return `
      <div class="offer-card" style="padding:12px;${isActive?'border-color:var(--green);background:rgba(16,185,129,.06)':''}">
        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
          <span style="font-size:32px">${sp.icon}</span>
          <div style="flex:1">
            <div style="font-weight:700;font-size:14px;color:var(--text)">${sp.name}</div>
            <div style="font-size:11px;color:var(--text2);margin-top:3px">${sp.benefit}</div>
            <div style="font-size:11px;color:var(--text3)">Cost: ${sp.cost.toLocaleString('ca')}€ · Prestigi mínim: ⭐${sp.prestigi_req}</div>
          </div>
          ${isActive ? '<span style="color:var(--green);font-weight:700;font-size:13px">✅ Actiu</span>' :
            `<button class="offer-btn" style="width:auto;padding:8px 14px;${!canAfford||!meetsReq?'opacity:.5;cursor:not-allowed':''}" 
              ${canAfford && meetsReq ? `onclick="activateSponsor('${sp.id}', ${sp.cost})"` : ''}>
              ${!meetsReq ? `⭐${sp.prestigi_req} necessari` : !canAfford ? 'Sense fons' : 'Activar'}
            </button>`}
        </div>
      </div>`;
  }).join('');
}

window.updateChannel = async function(chId, val) {
  if (!G.gameData.marketing) G.gameData.marketing = {channels: {}, sponsors: []};
  G.gameData.marketing.channels[chId] = parseInt(val);
  renderMarketing();
  await saveGameData();
};

window.activateSponsor = async function(id, cost) {
  if ((G.gameData.finances.cash || 0) < cost) { showToast('❌ No tens prou tresoreria'); return; }
  G.gameData.finances.cash -= cost;
  if (!G.gameData.marketing) G.gameData.marketing = {channels: {}, sponsors: []};
  if (!G.gameData.marketing.sponsors) G.gameData.marketing.sponsors = [];
  G.gameData.marketing.sponsors.push(id);
  G.gameData.prestigi = (G.gameData.prestigi || 0) + 5;
  await saveGameData();
  renderMarketing(); renderDashboard();
  showToast('🏟️ Patrocini activat!');
};

// ==================== SALES ====================
function renderSales() {
  const gd = G.gameData;
  const rev = gd.finances?.monthly_revenue || 0;
  const clients = gd.clients || [];
  const claims = gd.claims || [];

  document.getElementById('sales-summary').innerHTML = `
    Ingressos mensuals: <strong style="color:var(--green)">${rev.toLocaleString('ca')}€</strong><br>
    Clients actius: <strong style="color:var(--text)">${clients.length}</strong><br>
    Reclamacions obertes: <strong style="color:${claims.length>0?'var(--red)':'var(--green)'}">${claims.length}</strong><br>
    Ticket mitjà: <strong style="color:var(--text)">${clients.length>0?(rev/clients.length).toFixed(0):0}€</strong>`;

  document.getElementById('claims-list').innerHTML = claims.length === 0
    ? '<div style="color:var(--green);font-size:12px;text-align:center;padding:16px">✅ Sense reclamacions pendents</div>'
    : claims.map(cl => `
      <div class="notif-item urgent">
        <div class="notif-icon">⚠️</div>
        <div class="notif-body"><div class="notif-title">${cl.client}</div><div class="notif-desc">${cl.issue}</div></div>
        <button class="emp-btn fire" onclick="resolveClaim('${cl.id}')">Resoldre</button>
      </div>`).join('');

  document.getElementById('clients-list').innerHTML = clients.length === 0
    ? '<div style="color:var(--text2);font-size:13px;text-align:center;padding:20px">Sense clients. Ajusta la teva estratègia comercial i avança setmanes!</div>'
    : clients.map(cl => `
      <div class="notif-item">
        <div class="notif-icon">${cl.icon||'🏢'}</div>
        <div class="notif-body">
          <div class="notif-title">${cl.name}</div>
          <div class="notif-desc">${cl.type||'B2B'} · Comanda: ${(cl.monthly_value||0).toLocaleString('ca')}€/mes · Satisfacció: ${cl.satisfaction||70}%</div>
        </div>
        <div class="notif-time" style="color:var(--gold)">${(cl.monthly_value||0).toLocaleString('ca')}€</div>
      </div>`).join('');
}

window.resolveClaim = async function(id) {
  const cl = G.gameData.claims.find(c => c.id === id);
  if (!cl) return;
  G.gameData.claims = G.gameData.claims.filter(c => c.id !== id);
  G.gameData.finances.cash -= cl.compensation || 500;
  await saveGameData();
  renderSales(); renderFinances();
  showToast(`✅ Reclamació resolta. Cost: ${cl.compensation || 500}€`);
};

window.openNewClient = function() {
  showToast('📦 Funció disponible a la pròxima actualització del simulador');
};

// ==================== MAP ====================
function renderMap() {
  const canvas = document.getElementById('map-canvas');
  const vp = document.getElementById('map-viewport');
  if (!canvas || !vp) return;
  const W = 800, H = 600;
  canvas.width = W; canvas.height = H;
  const ctx = canvas.getContext('2d');

  // Background
  ctx.fillStyle = '#0d1225';
  ctx.fillRect(0, 0, W, H);

  // Grid
  ctx.strokeStyle = 'rgba(79,127,255,0.06)';
  ctx.lineWidth = 1;
  for (let x = 0; x < W; x += 40) { ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke(); }
  for (let y = 0; y < H; y += 40) { ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke(); }

  // Title regions
  ctx.fillStyle = 'rgba(79,127,255,0.04)';
  ctx.beginPath(); ctx.roundRect(20, 20, 370, H-40, 8); ctx.fill();
  ctx.fillStyle = 'rgba(124,58,237,0.04)';
  ctx.beginPath(); ctx.roundRect(410, 20, 370, H-40, 8); ctx.fill();

  ctx.fillStyle = 'rgba(79,127,255,0.3)';
  ctx.font = '11px "JetBrains Mono", monospace';
  ctx.fillText('VALLÈS OCCIDENTAL', 30, 38);
  ctx.fillStyle = 'rgba(124,58,237,0.5)';
  ctx.fillText('VALLÈS ORIENTAL', 420, 38);

  // Roads (simplified)
  ctx.strokeStyle = 'rgba(100,120,180,0.2)';
  ctx.lineWidth = 2;
  const roads = [[0,180,W,180],[0,320,W,320],[0,450,W,450],[190,0,190,H],[400,0,400,H],[600,0,600,H]];
  roads.forEach(r => { ctx.beginPath(); ctx.moveTo(r[0],r[1]); ctx.lineTo(r[2],r[3]); ctx.stroke(); });

  // Convert geo coords to canvas (approximate Vallès region)
  const geoToCanvas = (lat, lon) => {
    const latMin = 41.45, latMax = 41.90, lonMin = 1.95, lonMax = 2.55;
    return [
      Math.round((lon - lonMin) / (lonMax - lonMin) * (W - 60)) + 30,
      Math.round((latMax - lat) / (latMax - latMin) * (H - 60)) + 30
    ];
  };

  // Background companies
  VALLES_EMPRESES.slice(0, 15).forEach(e => {
    const [x, y] = geoToCanvas(e.loc[0], e.loc[1]);
    const sectorD = SECTORS.find(s => s.id === e.sector);
    ctx.fillStyle = 'rgba(100,120,200,0.15)';
    ctx.beginPath(); ctx.arc(x, y, 5, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle = 'rgba(150,170,255,0.35)';
    ctx.font = '11px sans-serif';
    ctx.fillText(sectorD?.icon || '🏢', x-6, y+4);
  });

  // Other players
  G.otherPlayers.forEach(p => {
    if (!p.company) return;
    const [x, y] = geoToCanvas(
      41.55 + Math.random() * 0.3,
      2.05 + Math.random() * 0.4
    );
    ctx.fillStyle = 'rgba(124,58,237,0.4)';
    ctx.beginPath(); ctx.arc(x, y, 8, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle = '#a78bfa';
    ctx.font = 'bold 10px "Space Grotesk", sans-serif';
    ctx.fillText(p.displayName?.charAt(0) || '?', x-3, y+4);
  });

  // My company
  if (G.gameData.company) {
    const c = G.gameData.company;
    const [x, y] = geoToCanvas(41.68 + Math.random()*0.05, 2.18 + Math.random()*0.05);
    // Pulse
    ctx.fillStyle = 'rgba(79,127,255,0.15)';
    ctx.beginPath(); ctx.arc(x, y, 18, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle = 'rgba(79,127,255,0.3)';
    ctx.beginPath(); ctx.arc(x, y, 12, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle = '#4f7fff';
    ctx.beginPath(); ctx.arc(x, y, 7, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle = '#fff';
    ctx.font = 'bold 9px "Space Grotesk"';
    ctx.fillText(c.name.charAt(0), x-3, y+3);
    // Label
    ctx.fillStyle = 'rgba(14,20,45,0.9)';
    const labelW = ctx.measureText(c.name).width + 16;
    ctx.beginPath(); ctx.roundRect(x-labelW/2, y+12, labelW, 18, 4); ctx.fill();
    ctx.fillStyle = '#93bbff';
    ctx.font = '9px "Space Grotesk"';
    ctx.fillText(c.name, x-labelW/2+8, y+25);
    G.myMapPos = [x, y];
  }

  document.getElementById('map-info').textContent = `${G.otherPlayers.length} altres empreses actives`;
}

function renderRanking() {
  const all = [...G.otherPlayers, G.gameData].filter(p => p && p.company);
  all.sort((a, b) => (b.finances?.cash || 0) - (a.finances?.cash || 0));
  document.getElementById('rank-body').innerHTML = all.slice(0, 15).map((p, i) => `
    <div class="rank-row ${p.uid === G.uid ? 'me' : ''}" onclick="">
      <div class="rank-num">${i+1}</div>
      <div class="rank-name">${p.company?.sectorData?.icon || '🏢'} ${p.displayName || '—'}</div>
      <div class="rank-info">${p.company?.name || '—'}</div>
      <div class="rank-val">${(p.finances?.cash || 0).toLocaleString('ca')}€</div>
    </div>`).join('') || '<div style="color:var(--text2);font-size:13px;text-align:center;padding:16px">Sense empreses actives</div>';
}

window.toggleRanking = function() {
  const drawer = document.getElementById('ranking-drawer');
  drawer.classList.toggle('open');
  G.rankingOpen = !G.rankingOpen;
};

// ==================== WEEK ADVANCE ====================
window.advanceWeek = async function() {
  if (!G.gameData.mode) { showToast('⚠️ Crea o incorpora\'t a una empresa primer!'); return; }
  const gd = G.gameData;
  gd.week++;
  // Month/year progression
  const weekInYear = ((gd.week - 1) % 52) + 1;
  gd.month = Math.ceil(weekInYear / 4.33);
  if (gd.week > 1 && (gd.week - 1) % 52 === 0) {
    gd.year++;
    endOfYear();
  }

  // Revenue simulation
  const emps = gd.employees || [];
  const salesEmps = emps.filter(e => e.dept === 'vendes').length;
  const machines = gd.machines || [];
  const capacity = machines.reduce((s, m) => s + m.capacity, 0);
  const mktChannels = gd.marketing?.channels || {};
  const mktSpend = Object.values(mktChannels).reduce((s, v) => s + v, 0);
  const sponsors = gd.marketing?.sponsors || [];
  const prestigi = gd.prestigi || 0;

  // Base revenue calculation
  let baseRev = capacity * 0.8 * 5; // 5€ per unit
  baseRev += salesEmps * 3500; // Each sales person generates 3500/week
  baseRev += mktSpend * 2.5; // Marketing ROI
  baseRev += sponsors.length * 800;
  baseRev += prestigi * 50;
  baseRev = Math.max(baseRev, 0);

  // Costs
  const salaries = emps.reduce((s, e) => s + e.salary * 1.3, 0) / 4.33;
  const rent = (gd.company?.monthlyRent || 0) / 4.33;
  const maintenance = machines.reduce((s, m) => s + (m.maintenance || 0), 0) / 4.33;
  const loanPayments = (gd.finances.loans || []).reduce((s, l) => s + l.monthlyPayment / 4.33, 0);
  const totalCosts = salaries + rent + maintenance + loanPayments + mktSpend / 4.33;

  // Apply active events
  let revenueMultiplier = 1;
  (gd.events || []).forEach(ev => {
    if (ev.weeksLeft > 0) revenueMultiplier += ev.impact;
  });
  // Reduce weeks left
  gd.events = (gd.events || []).map(ev => ({...ev, weeksLeft: ev.weeksLeft - 1})).filter(ev => ev.weeksLeft > 0);

  const weekRev = baseRev * revenueMultiplier;
  const weekResult = weekRev - totalCosts;

  gd.finances.cash = (gd.finances.cash || 0) + weekResult;
  gd.finances.monthly_revenue = weekRev * 4.33;
  gd.finances.monthly_costs = totalCosts * 4.33;
  gd.finances.annual_revenue = (gd.finances.annual_revenue || 0) + weekRev;
  gd.finances.annual_costs = (gd.finances.annual_costs || 0) + totalCosts;
  gd.finances.actiu.tresoreria = gd.finances.cash;

  // Revenue history
  if (!gd.finances.revenue_history) gd.finances.revenue_history = [];
  gd.finances.revenue_history.push({week: gd.week, rev: weekRev, costs: totalCosts, result: weekResult});
  if (gd.finances.revenue_history.length > 52) gd.finances.revenue_history.shift();

  // Morale drift
  emps.forEach(e => {
    if (gd.finances.cash < 0) e.morale = Math.max(0, (e.morale||60) - 5);
    else e.morale = Math.min(100, (e.morale||60) + 1);
    e.seniority = (e.seniority || 0) + 1/52;
  });

  // Client acquisition (simplified)
  if (Math.random() < 0.15 + prestigi * 0.01) {
    const clientTypes = ['🏢 Empresa industrial','🏪 Comerç local','🏥 Centre mèdic','🏫 Centre educatiu','🏨 Hotel'];
    const newClient = {
      id:'cl_'+Date.now(), icon:'🤝',
      name: clientTypes[Math.floor(Math.random()*clientTypes.length)],
      type: Math.random() > 0.5 ? 'B2B' : 'B2C',
      monthly_value: Math.round(500 + Math.random() * 5000),
      satisfaction: 70 + Math.floor(Math.random()*25),
    };
    if (!gd.clients) gd.clients = [];
    gd.clients.push(newClient);
    showEventToast('🤝', 'Nou client!', `${newClient.name} vol contractar els teus serveis!`, true);
    gd.notifications.push({id:Date.now(), icon:'🤝', title:'Nou client!', desc:`${newClient.name} s'incorpora com a client`, time:`S${gd.week}`, urgent:false});
  }

  // Random claims
  if (gd.clients?.length > 0 && Math.random() < 0.08) {
    const cl = gd.clients[Math.floor(Math.random()*gd.clients.length)];
    const issue = ['Retard en el lliurament','Defecte en el producte','Error en la facturació','Mala atenció al client'][Math.floor(Math.random()*4)];
    if (!gd.claims) gd.claims = [];
    gd.claims.push({id:'claim_'+Date.now(), client:cl.name, issue, compensation:Math.round(200+Math.random()*1000)});
    gd.notifications.push({id:Date.now(), icon:'⚠️', title:'Reclamació!', desc:`${cl.name}: ${issue}`, time:`S${gd.week}`, urgent:true});
    showEventToast('⚠️', 'Reclamació!', `${cl.name}: ${issue}`, false);
  }

  // Random events
  if (Math.random() < 0.12) {
    const ev = EVENT_POOL[Math.floor(Math.random()*EVENT_POOL.length)];
    if (Math.random() < ev.probability * 5) {
      const activeEv = {...ev, id:'ev_'+Date.now(), weeksLeft: ev.duration || 1};
      gd.events.push(activeEv);
      const impact = ev.impact >= 0 ? `+${(ev.impact*100).toFixed(0)}%` : `${(ev.impact*100).toFixed(0)}%`;
      gd.notifications.push({id:Date.now(), icon:ev.icon, title:ev.title, desc:ev.desc + ` (Impacte: ${impact})`, time:`S${gd.week}`, urgent:ev.impact<0});
      showEventToast(ev.icon, ev.title, ev.desc, ev.impact >= 0);
    }
  }

  // Prestigi update
  if (weekResult > 0) gd.prestigi = Math.min(100, (gd.prestigi||0) + 0.1);
  else if (weekResult < -5000) gd.prestigi = Math.max(0, (gd.prestigi||0) - 0.2);

  // Insolvency check
  if (gd.finances.cash < -50000) {
    gd.notifications.push({id:Date.now(), icon:'🚨', title:'ALERTA: Concurs de creditors', desc:'La tresoreria és críticament negativa. Risc de suspensió de pagaments.', time:`S${gd.week}`, urgent:true});
    showEventToast('🚨', 'Alerta financera!', 'Tresoreria crítica. Risc de suspensió de pagaments!', false);
  }

  document.getElementById('week-display').textContent = `Setmana ${gd.week} · ${gd.year}`;
  updateTopStats();
  renderDashboard(); renderFinances(); renderHR(); renderProduction(); renderMarketing(); renderSales();
  if (G.currentTab === 'map') renderMap();

  showToast(`⏩ Setmana ${gd.week} · Resultat: ${weekResult >= 0 ? '+' : ''}${weekResult.toFixed(0)}€`);
  await saveGameData();
};

function endOfYear() {
  const gd = G.gameData;
  const annualResult = (gd.finances.annual_revenue || 0) - (gd.finances.annual_costs || 0);
  const tax = Math.max(0, annualResult * 0.25); // IS 25%
  gd.finances.cash -= tax;
  gd.finances.passiu.reserves = (gd.finances.passiu.reserves || 0) + Math.max(0, annualResult - tax);
  gd.finances.annual_revenue = 0;
  gd.finances.annual_costs = 0;
  gd.notifications.push({id:Date.now(), icon:'📊', title:`Tancament any ${gd.year-1}`, desc:`Resultat: ${annualResult.toFixed(0)}€. IS pagat: ${tax.toFixed(0)}€. Noves reserves: ${Math.max(0,annualResult-tax).toFixed(0)}€`, time:'31/12', urgent:false});
  showEventToast('📊', `Tancament any ${gd.year-1}`, `Resultat: ${annualResult.toFixed(0)}€ · Impost: ${tax.toFixed(0)}€`, annualResult >= 0);
}

// ==================== LOAN ====================
window.requestLoan = async function() {
  if (!G.gameData.company) { showToast('⚠️ Crea una empresa primer'); return; }
  const amount = parseFloat(document.getElementById('loan-amount').value || 0);
  const years = parseInt(document.getElementById('loan-years').value || 7);
  if (amount < 5000) { showToast('⚠️ Import mínim: 5.000€'); return; }
  const interest = 5.5;
  const monthlyPayment = Math.round(amount * (interest/100/12) / (1 - Math.pow(1+interest/100/12, -years*12)));
  const approved = Math.random() > 0.25; // 75% approval
  if (!approved) {
    document.getElementById('loan-result').innerHTML = `<span style="color:var(--red)">❌ Sol·licitud denegada. Millora el teu historial de crèdit o aporta avals.</span>`;
    return;
  }
  G.gameData.finances.cash += amount;
  G.gameData.finances.passiu.deutes_llarg = (G.gameData.finances.passiu.deutes_llarg || 0) + amount;
  G.gameData.finances.loans = G.gameData.finances.loans || [];
  G.gameData.finances.loans.push({id:'loan_'+Date.now(), amount, remaining:amount, interest, years, monthlyPayment, startWeek:G.gameData.week});
  await saveGameData();
  renderFinances(); renderDashboard(); renderActiveCompany();
  document.getElementById('loan-result').innerHTML = `<span style="color:var(--green)">✅ Préstec de ${amount.toLocaleString('ca')}€ aprovat! Quota mensual: ${monthlyPayment.toLocaleString('ca')}€</span>`;
};

// ==================== NAV ====================
window.showTab = function(tab) {
  G.currentTab = tab;
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + tab)?.classList.add('active');
  document.getElementById('nav-' + tab)?.classList.add('active');
  if (tab === 'map') { setTimeout(() => { renderMap(); renderRanking(); }, 100); }
  if (tab === 'dashboard') renderDashboard();
  if (tab === 'finances') renderFinances();
  if (tab === 'hr') renderHR();
  if (tab === 'production') renderProduction();
  if (tab === 'marketing') renderMarketing();
  if (tab === 'sales') renderSales();
};

// ==================== PROFILE ====================
window.openProfile = function() {
  const gd = G.gameData;
  document.getElementById('modal-username').textContent = gd.displayName || '—';
  document.getElementById('modal-email').textContent = G.user?.email || '—';
  const stats = [
    {v: gd.prestigi || 0, l: 'Prestigi'},
    {v: gd.week || 1, l: 'Setmana'},
    {v: gd.employees?.length || 0, l: 'Empleats'},
    {v: (gd.finances?.cash || 0).toLocaleString('ca') + '€', l: 'Tresoreria'},
    {v: gd.clients?.length || 0, l: 'Clients'},
    {v: gd.machines?.length || 0, l: 'Màquines'},
  ];
  document.getElementById('profile-stats').innerHTML = stats.map(s => `
    <div class="sg-box" style="background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:10px;padding:12px;text-align:center">
      <div style="font-size:18px;font-weight:700;font-family:'JetBrains Mono',monospace;color:var(--gold)">${s.v}</div>
      <div style="font-size:9px;color:var(--text2);margin-top:3px;font-weight:600;text-transform:uppercase;letter-spacing:.5px">${s.l}</div>
    </div>`).join('');
  document.getElementById('profile-modal').style.display = 'flex';
};

window.closeProfile = function() { document.getElementById('profile-modal').style.display = 'none'; };

// ==================== EVENTS/TOASTS ====================
function showEventToast(icon, title, desc, isPos) {
  const container = document.getElementById('events-container');
  const toast = document.createElement('div');
  toast.className = 'event-toast';
  toast.innerHTML = `
    <div class="event-icon">${icon}</div>
    <div class="event-body">
      <div class="event-title" style="color:${isPos?'var(--green)':'var(--red)'}">${title}</div>
      <div class="event-desc">${desc}</div>
    </div>`;
  container.appendChild(toast);
  toast.addEventListener('click', () => toast.remove());
  setTimeout(() => toast.remove(), 6000);
}

function showToast(msg) {
  const list = document.getElementById('toast-list');
  const t = document.createElement('div');
  t.className = 'toast';
  t.textContent = msg;
  list.appendChild(t);
  setTimeout(() => t.remove(), 2800);
}

function updateTopStats() {
  const gd = G.gameData;
  if (!gd) return;
  const date = `S${gd.week} · ${gd.year}`;
  const cash = (gd.finances?.cash || 0).toLocaleString('ca') + '€';
  const rev = gd.finances?.monthly_revenue || 0;
  const costs = gd.finances?.monthly_costs || 0;
  const result = rev - costs;
  document.getElementById('stat-date').textContent = date;
  document.getElementById('stat-cash').textContent = cash;
  document.getElementById('stat-result').textContent = (result >= 0 ? '+' : '') + result.toFixed(0) + '€/mes';
  const resultStat = document.getElementById('stat-result').parentElement;
  resultStat.className = 'tstat ' + (result >= 0 ? 'green' : 'red');
  document.getElementById('stat-prestigi').textContent = gd.prestigi?.toFixed(1) || 0;
  document.getElementById('stat-emp').textContent = gd.employees?.length || 0;
}

window.markRead = function(id) {
  const n = G.gameData.notifications?.find(n => n.id == id);
  if (n) n.read = true;
};

// Keyboard shortcuts
document.addEventListener('keydown', e => {
  if (e.key === ' ' && e.ctrlKey) { e.preventDefault(); advanceWeek(); }
});

console.log('🏢 EmpresaBat carregat correctament');
</script>
</body>
</html>
